---
layout: none
permalink: api/farmers
---
[
  {% for farmer in site.farmers %}
    {
      "layout": {{ farmer['layout'] | jsonify }},
      "url": {{ farmer['url'] | jsonify }},
      "title": {{ farmer['title'] | jsonify }},
      "location": {{ farmer['location'] | jsonify }},
      "vendorID": {{ farmer['vendorID'] | jsonify }},
      "featuredImage": {{ farmer['featured_image'] | jsonify }},
      "content": {{ farmer['content'] | jsonify }},
      "categories": {{ farmer['categories'] | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]